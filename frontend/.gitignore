# Create .gitignore file
echo "# Dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Build files
/build
/dist
/frontend/build

# Environment files
.env
.env.local
.env.*.local
!.env.example

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Temporary files
.tmp/
temp/
*.tmp
*.temp

# Backup files
*.bak
*.backup
" > .gitignore